PORT=3001

# Supabase Postgres connection string (Session pooler URI)
# From Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# If your password contains special characters (e.g. @, #, :), URL-encode it.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Optional alias supported by this app
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
